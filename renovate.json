{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["msi-installer/src/msi_installer/wix-toolchain\\.toml$"],
      "matchStrings": [
        "version\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\n.*github\\.com/(?<depName>[^/]+/[^/]+)/"
      ],
      "datasourceTemplate": "github-releases"
    }
  ]
}
