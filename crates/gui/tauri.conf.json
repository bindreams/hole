{
  "productName": "Hole",
  "identifier": "com.hole.app",
  "build": {
    "frontendDist": "../../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost data:",
        "font-src": "'self'"
      }
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      ".cache/v2ray-plugin/v2ray-plugin"
    ],
    "icon": [
      ".cache/icons/32x32.png",
      ".cache/icons/128x128.png",
      ".cache/icons/icon.icns",
      ".cache/icons/icon.ico"
    ]
  }
}
