<?xml version="1.0" encoding="UTF-8"?>

<!--
  WiX installer for Hole.
  Installs to [ProgramFiles64Folder]\hole\bin\, registers the daemon service,
  and adds hole to the system PATH.

  Build:   cd msi-installer && uv run build
  Install: msiexec /i hole.msi
  Silent:  msiexec /i hole.msi /quiet
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Hole"
    Manufacturer="Hole Project"
    Version="$(ProductVersion)"
    UpgradeCode="6F2A8C1D-3E4B-4F5A-9D7E-1C2B3A4F5E6D">

    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of Hole is already installed." />

    <!-- Installation directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="hole">
        <Directory Id="BINDIR" Name="bin" />
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut directory -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="HoleMenuFolder" Name="Hole" />
    </StandardDirectory>

    <!-- Main component: binaries -->
    <ComponentGroup Id="BinaryComponents" Directory="BINDIR">
      <Component Id="HoleExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="hole.exe" Source="!(bindpath.BinDir)\hole.exe" KeyPath="yes" />
      </Component>
      <Component Id="V2rayPlugin" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="v2ray_plugin.exe" Source="!(bindpath.BinDir)\v2ray-plugin.exe" KeyPath="yes" />
      </Component>
      <Component Id="WintunDll" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <File Id="wintun.dll" Source="!(bindpath.BinDir)\wintun.dll" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Start Menu shortcut -->
    <ComponentGroup Id="ShortcutComponents" Directory="HoleMenuFolder">
      <Component Id="StartMenuShortcut" Guid="D4E5F6A7-B8C9-0123-DEF0-234567890123">
        <Shortcut
          Id="HoleShortcut"
          Name="Hole"
          Target="[BINDIR]hole.exe"
          WorkingDirectory="BINDIR" />
        <RemoveFolder Id="RemoveMenuFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Hole"
          Name="Installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Custom actions: daemon install/uninstall + PATH add/remove.
         Uses FileRef (Type 18) to reference hole.exe by its File ID,
         not Directory (Type 34) which fails to launch the exe. -->
    <CustomAction
      Id="DaemonInstall"
      FileRef="hole.exe"
      ExeCommand="daemon install"
      Execute="deferred"
      Impersonate="no"
      Return="check" />

    <CustomAction
      Id="PathAdd"
      FileRef="hole.exe"
      ExeCommand="path add"
      Execute="deferred"
      Impersonate="no"
      Return="check" />

    <CustomAction
      Id="PathRemove"
      FileRef="hole.exe"
      ExeCommand="path remove"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="DaemonUninstall"
      FileRef="hole.exe"
      ExeCommand="daemon uninstall"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <!-- Launch the app after a fresh interactive install.
         Runs as the installing user (Impersonate=yes), non-blocking (asyncNoWait).
         Skipped on upgrades (WIX_UPGRADE_DETECTED), uninstalls, and silent installs
         (pass SUPPRESS_LAUNCH=1 on the msiexec command line). -->
    <CustomAction
      Id="LaunchApp"
      FileRef="hole.exe"
      ExeCommand=""
      Execute="immediate"
      Impersonate="yes"
      Return="asyncNoWait" />

    <InstallExecuteSequence>
      <!-- Post-install: daemon install then PATH add -->
      <Custom Action="DaemonInstall" After="InstallFiles"
        Condition="NOT Installed AND NOT REMOVE" />
      <Custom Action="PathAdd" After="DaemonInstall"
        Condition="NOT Installed AND NOT REMOVE" />

      <!-- Pre-uninstall: PATH remove then daemon uninstall.
           Each uninstall CA must be transitively anchored Before RemoveFiles
           via explicit Before attributes, so ordering is fully determined. -->
      <Custom Action="PathRemove" Before="DaemonUninstall"
        Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="DaemonUninstall" Before="RemoveFiles"
        Condition="REMOVE=&quot;ALL&quot;" />

      <!-- Launch app after fresh install (not upgrades, not silent) -->
      <Custom Action="LaunchApp" After="InstallFinalize"
        Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED AND NOT REMOVE AND NOT SUPPRESS_LAUNCH" />
    </InstallExecuteSequence>

  </Package>
</Wix>
